# Copy to .env and fill in real values. Do NOT commit .env.

# Signed-cookie session secret. Generate any long random string.
SECRET_KEY=change-me-to-a-long-random-string

# SQLite file path (relative paths are resolved from the project root).
DATABASE_URL=sqlite:///library.db

# --- Google SSO (optional; app still runs with a dev-login fallback if unset) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JSON list of emails auto-promoted to admin on first login.
ADMIN_EMAILS=["you@example.com"]

# --- Gemini AI (optional; AI features degrade gracefully if unset) ---
# Provider: gemini_api (AI Studio key) or vertex_ai (Google Cloud Vertex AI)
AI_PROVIDER=gemini_api

# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Vertex AI settings (required when AI_PROVIDER=vertex_ai)
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# Base URL used when building OAuth redirect URIs. Change for deployed env.
APP_BASE_URL=http://localhost:8000
